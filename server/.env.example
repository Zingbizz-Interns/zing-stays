PORT=4000
DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=verify-full
JWT_SECRET=your_32_char_secret_here
JWT_EXPIRES_IN=7d

# Redis (for rate limiting and caching)
# Local:   redis://localhost:6379
# Upstash: rediss://default:TOKEN@ENDPOINT.upstash.io:PORT
REDIS_URL=redis://localhost:6379

# Email OTP
OTP_DEV_CONSOLE_FALLBACK=false
OTP_EMAIL_FROM=no-reply@example.com
OTP_EMAIL_SUBJECT=Your ZingBrokers verification code
OTP_EMAIL_TEXT_TEMPLATE=Your ZingBrokers verification code is {CODE}. It expires in 10 minutes.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password

# Meilisearch
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=your_master_key

# ImageKit
IMAGEKIT_PUBLIC_KEY=public_xxxx
IMAGEKIT_PRIVATE_KEY=private_xxxx
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_id

# Client URL (for CORS)
CLIENT_URL=http://localhost:3000

# Admin email
ADMIN_EMAIL=admin@example.com

# PostHog (client-side analytics)
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# PostHog server-side / build-time (for generateStaticParams HogQL query)
# Create a personal API key at: https://app.posthog.com/settings/user-api-keys
# Project ID is visible in PostHog → Settings → General
POSTHOG_PERSONAL_API_KEY=phx_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
POSTHOG_PROJECT_ID=12345
